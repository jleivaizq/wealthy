{
  "name": "wealthy",
  "version": "0.0.0",
  "license": "MIT",
  "prisma": {
    "schema": "libs/api/data-access-db/src/lib/schema.prisma"
  },
  "scripts": {
    "start:dev": "env-cmd -f .local.env concurrently --kill-others \"npm:db:up\" \"npm:start:api\" \"npm:start:web\" ",
    "start:api": "nx serve api",
    "start:web": "nx serve web",
    "build": "nx build",
    "test": "nx test",
    "DATABASE": "-----------------------------------------------------------------------------------------------",
    "db:up": "npm run db:docker && npm run db:dev-migrate && npm run db:create-client -- --watch",
    "db:docker": "docker-compose -f tools/docker-env/dev.docker-compose.yml up -d --no-recreate --remove-orphans",
    "db:create-client": "prisma generate",
    "db:dev-migrate": "env-cmd --no-override -f .local.env npx prisma migrate dev",
    "db:studio": "env-cmd --no-override -f .local.env npx prisma studio",
    "UTILS": "---------------------------------------------------------------------------------------------------",
    "gen:gql": "graphql-codegen --config tools/gql-codegen/gql-codegen.yml --watch"
  },
  "private": true,
  "dependencies": {
    "@fastify/cookie": "^6.0.0",
    "@nestjs/common": "^9.0.0",
    "@nestjs/core": "^9.0.0",
    "@nestjs/graphql": "^10.1.7",
    "@nestjs/jwt": "^9.0.0",
    "@nestjs/mercurius": "^10.1.7",
    "@nestjs/passport": "^9.0.0",
    "@nestjs/platform-express": "^9.0.0",
    "@nestjs/platform-fastify": "^9.2.1",
    "@prisma/client": "^4.7.1",
    "bcrypt": "^5.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.13.2",
    "core-js": "^3.6.5",
    "graphql": "^16.6.0",
    "helmet": "^6.0.1",
    "mercurius": "^10.5.1",
    "next": "13.0.0",
    "passport-jwt": "^4.0.0",
    "passport-local": "^1.0.0",
    "prisma-nestjs-graphql": "^17.0.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "reflect-metadata": "^0.1.13",
    "regenerator-runtime": "0.13.7",
    "rxjs": "^7.0.0",
    "tslib": "^2.3.0",
    "urql": "^3.0.3"
  },
  "devDependencies": {
    "@babel/preset-react": "^7.14.5",
    "@graphql-codegen/cli": "^2.16.1",
    "@graphql-codegen/near-operation-file-preset": "^2.4.4",
    "@graphql-codegen/typed-document-node": "^2.3.10",
    "@graphql-codegen/typescript": "^2.8.5",
    "@graphql-codegen/typescript-operations": "^2.5.10",
    "@graphql-codegen/typescript-urql": "^3.7.3",
    "@nestjs/schematics": "^9.0.0",
    "@nestjs/testing": "^9.0.0",
    "@nrwl/cli": "15.0.1",
    "@nrwl/cypress": "15.3.0",
    "@nrwl/eslint-plugin-nx": "15.0.1",
    "@nrwl/jest": "15.3.0",
    "@nrwl/linter": "15.0.1",
    "@nrwl/nest": "15.0.1",
    "@nrwl/next": "^15.3.0",
    "@nrwl/node": "15.0.1",
    "@nrwl/nx-cloud": "latest",
    "@nrwl/react": "15.3.0",
    "@nrwl/web": "15.3.0",
    "@nrwl/workspace": "15.0.1",
    "@testing-library/react": "13.4.0",
    "@types/jest": "28.1.1",
    "@types/node": "16.11.7",
    "@types/react": "18.0.25",
    "@types/react-dom": "18.0.9",
    "@typescript-eslint/eslint-plugin": "^5.36.1",
    "@typescript-eslint/parser": "^5.36.1",
    "babel-jest": "28.1.1",
    "concurrently": "^7.6.0",
    "cypress": "^11.0.0",
    "env-cmd": "^10.1.0",
    "eslint": "^8.29.0",
    "eslint-config-next": "13.0.0",
    "eslint-config-prettier": "8.1.0",
    "eslint-plugin-cypress": "^2.10.3",
    "eslint-plugin-import": "2.26.0",
    "eslint-plugin-jsx-a11y": "6.6.1",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-react": "7.31.11",
    "eslint-plugin-react-hooks": "4.6.0",
    "eslint-plugin-unicorn": "^45.0.1",
    "graphql-codegen": "^0.4.0",
    "jest": "28.1.1",
    "jest-environment-jsdom": "28.1.1",
    "nx": "15.0.1",
    "prettier": "^2.6.2",
    "prisma": "^4.7.1",
    "react-test-renderer": "18.2.0",
    "ts-jest": "28.0.5",
    "ts-node": "10.9.1",
    "typescript": "~4.8.2"
  }
}
